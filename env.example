# Database
# Local (host): postgresql://USER:PASS@127.0.0.1:5432/articles
# Docker Compose sets DATABASE_URL automatically (host "postgres"); no need to set it here.
DATABASE_URL=

# PostgreSQL credentials used by docker-compose (postgres service + app DATABASE_URL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=articles

# Server
PORT=3030
# Host port mapped to the container (docker-compose)
APP_PORT=3030
NODE_ENV=development


# asset base url  eg: https://asset.articles.live
ASSET_BASE_URL=

# storage  type: local、aws、gcs
STORAGE_TYPE=aws

# local files store path
FILES_STORE=files

# AWS 
AWS_REGION=
AWS_ACCESS_ID=
AWS_ACCESS_KEY=
AWS_DISTRIBUTION_ID=
AWS_BUCKET=

# 
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_KEY_FILE_PATH=
GOOGLE_CLOUD_STORAGE_ID=

